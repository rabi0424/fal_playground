// Cloudflare Workers の設定
// 静的アセット配信 + 端末間同期 API（worker.js / Durable Object）
{
  "name": "fal-playground",
  "main": "worker.js",
  "compatibility_date": "2026-07-09",
  "assets": {
    "directory": "./"
  },
  "durable_objects": {
    "bindings": [
      { "name": "STATE", "class_name": "SyncState" }
    ]
  },
  // 無料プランでは SQLite バックエンドの Durable Object のみ利用可能
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SyncState"] }
  ]
}
